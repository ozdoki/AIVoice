{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capability.json",
  "identifier": "default",
  "description": "Default capability for AIVoice",
  "windows": ["main", "floating-bar"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-position",
    "core:window:allow-current-monitor",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load"
  ]
}
